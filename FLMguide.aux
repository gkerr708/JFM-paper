\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces  Fit parameters for sigmoid and Weibull functions describing the relationship between failure-mode frequency and viscosity or draw velocity (see Eq.\hphantom  {0}\ref {eq:sigmoid_c} and \ref {eq:sigmoid_e} for sigmoid; Eq.\hphantom  {0}\ref {eq:weibull} for Weibull). $Z$--70\%, $Z$--80\%, and $Z$--90\% correspond to zein solutions in 70\%, 80\%, and 90\% ethanol. $D$ corresponds to 500\,kDa dextran in water. }}{9}{table.caption.4}\protected@file@percent }
\newlabel{tab:fit_parameters}{{1}{9}{Fit parameters for sigmoid and Weibull functions describing the relationship between failure-mode frequency and viscosity or draw velocity (see Eq.~\ref {eq:sigmoid_c} and \ref {eq:sigmoid_e} for sigmoid; Eq.~\ref {eq:weibull} for Weibull). $Z$--70\%, $Z$--80\%, and $Z$--90\% correspond to zein solutions in 70\%, 80\%, and 90\% ethanol. $D$ corresponds to 500\,kDa dextran in water}{table.caption.4}{}}
