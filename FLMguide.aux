\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces  Failure mode distributions at three ethanol concentrations: 70\% (A,B), 80\% (C,D), and 90\% (E,F). Panels (A), (C), and (E): fraction of successful, capillary, and elastic failures as a function of solution viscosity, with sigmoid fits. Panels (B), (D), and (F): corresponding failure mode fractions as a function of draw velocity at fixed zein concentrations (49\% for 70\% and 80\% ethanol, 44\% for 90\% ethanol). Concentrations were chosen near the peak success rate observed for each solvent condition. Panels (G) and (H): failure mode distributions for 500kDa dextran solutions (adapted from \cite  {chowdhry_polymer_2021}) }}{8}{figure.caption.3}\protected@file@percent }
\newlabel{fig:failure_modes}{{3}{8}{Failure mode distributions at three ethanol concentrations: 70\% (A,B), 80\% (C,D), and 90\% (E,F). Panels (A), (C), and (E): fraction of successful, capillary, and elastic failures as a function of solution viscosity, with sigmoid fits. Panels (B), (D), and (F): corresponding failure mode fractions as a function of draw velocity at fixed zein concentrations (49\% for 70\% and 80\% ethanol, 44\% for 90\% ethanol). Concentrations were chosen near the peak success rate observed for each solvent condition. Panels (G) and (H): failure mode distributions for 500kDa dextran solutions (adapted from \cite {chowdhry_polymer_2021})}{figure.caption.3}{}}
\newlabel{eq:weibull}{{2.2}{8}{}{equation.2.2}{}}
